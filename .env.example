# Gemini Developer API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Gemini model id to use for layout extraction. Update this to whatever
# current vision-capable Gemini model your API key has access to.
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud Vision API key, used for OCR (TEXT_DETECTION). Enable the
# Cloud Vision API in your GCP project, then create an API key for it
# (https://console.cloud.google.com/apis/credentials). Separate from
# GOOGLE_API_KEY above — Gemini and Cloud Vision keys are provisioned
# independently even within the same GCP project.
GOOGLE_CLOUD_VISION_API_KEY=
